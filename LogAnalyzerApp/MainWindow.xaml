<Window x:Class="LogAnalyzerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Log Analyzer Dashboard"
        Height="650"
        Width="1000"
        Background="#1E1E2F"
        >
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3A3A5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Enterprise Log Analyzer"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <!-- FILE SECTION -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <Border Background="#2B2B40" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                 Text="{Binding FilePath}"
                 IsReadOnly="True"
                 Height="35"
                 Margin="0,0,10,0"
                 Background="#3A3A55"
                 Foreground="White"
                 BorderThickness="0"
                 Padding="8"/>

                <Button Grid.Column="1"
                Content="Browse"
                Command="{Binding BrowseCommand}"
                Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                Content="Analyse"
                Command="{Binding AnalyzeCommand}"
                IsEnabled="{Binding CanAnalyze}"/>

                </Grid>

            </Border>
        </StackPanel>

        <!-- SUMMARY CARDS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">

            <!-- INFO CARD -->
            <Border Background="#17A2B8"
                    CornerRadius="10"
                    Width="200"
                    Height="100"
                    Margin="10">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="INFO"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding InfoCount}"
                               FontSize="30"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- WARN CARD -->
            <Border Background="#FFC107"
                    CornerRadius="10"
                    Width="200"
                    Height="100"
                    Margin="10">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="WARN"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="Black"/>
                    <TextBlock Text="{Binding WarnCount}"
                               FontSize="30"
                               Foreground="Black"/>
                </StackPanel>
            </Border>

            <!-- ERROR CARD -->
            <Border Background="#DC3545"
                    CornerRadius="10"
                    Width="200"
                    Height="100"
                    Margin="10">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="ERROR"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding ErrorCount}"
                               FontSize="30"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- DATA GRID -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- PIE CHART -->
            <Border Background="#2B2B40" CornerRadius="10" Margin="0,0,10,0" Padding="10">
                <oxy:PlotView Model="{Binding PieModel}" />
            </Border>

            <!-- DATA GRID -->
            <DataGrid Grid.Column="1"
              ItemsSource="{Binding ModuleErrors}"
              AutoGenerateColumns="False"
              Background="#2D2D44"
              Foreground="White"
              RowBackground="#2D2D44"
              AlternatingRowBackground="#252538"
              GridLinesVisibility="None"
              BorderThickness="0"
              IsReadOnly="True"
              CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Module"
                                Binding="{Binding Module}"
                                Width="*"/>

                    <DataGridTextColumn Header="Error Count"
                                Binding="{Binding Count}"
                                Width="150"/>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StatusBar Grid.Row="4"
           Background="White"
           Height="30">

            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                   FontSize="13"/>
            </StatusBarItem>

        </StatusBar>
    </Grid>
</Window>